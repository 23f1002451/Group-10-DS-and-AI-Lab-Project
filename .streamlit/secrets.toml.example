# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to Git — it is already in .gitignore.
#
# On Streamlit Community Cloud, paste these key=value pairs into the
# "Secrets" panel under App Settings (without the [section] headers).
# ─────────────────────────────────────────────────────────────────────────

# ── Gemini API ────────────────────────────────────────────────────────────
# Required for live LLM responses.
# Obtain a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "your-gemini-api-key-here"

# Optional: override the Gemini model name (default: gemini-2.5-flash)
# GEMINI_MODEL_NAME = "gemini-2.5-flash"

# ── Model checkpoint ──────────────────────────────────────────────────────
# Relative path from the repo root (default: models/final_model.pt).
# Only change this if you renamed or moved the checkpoint.
# CHECKPOINT_PATH = "models/final_model.pt"

# Optional: direct HTTPS download URL for the checkpoint.
# If set, the app will auto-download the file on first startup when
# models/final_model.pt is missing (useful for Streamlit Cloud).
#
# Supported sources:
#   - GitHub Releases raw asset URL
#   - HuggingFace Hub raw file URL
#   - Google Drive direct export link  (https://drive.google.com/uc?export=download&id=FILE_ID)
#
# MODEL_DOWNLOAD_URL = "https://example.com/final_model.pt"

# ── Guardrail thresholds (optional overrides) ─────────────────────────────
# BLOCK_THRESHOLD     = "0.8"   # p_attack >= this → BLOCK
# TRANSFORM_THRESHOLD = "0.3"   # p_attack >= this → TRANSFORM

# ── Feature flags (optional overrides) ───────────────────────────────────
# ENABLE_OUTPUT_GUARDRAIL = "true"
# ENABLE_RULE_FILTER      = "true"
